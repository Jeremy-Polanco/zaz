# ── DashGo Mobile (Expo) ──────────────────────────────────────────
# Only EXPO_PUBLIC_* vars are exposed to the app bundle.
# Copy to `.env` for local development.

# Base URL of the DashGo API
EXPO_PUBLIC_API_URL=http://localhost:3002/api

# Stripe publishable key (test mode for local dev)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Sentry DSN (optional locally; required in production builds)
# EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# OTP mode (optional). Phone-only login is the DEFAULT when unset. Set to
# `whatsapp` or `sandbox` to re-enable the verified (OTP code) login flow —
# this MUST match the backend AUTH_OTP_MODE.
# EXPO_PUBLIC_AUTH_OTP_MODE=whatsapp
