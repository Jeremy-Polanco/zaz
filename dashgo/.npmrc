# Force a flat (hoisted) node_modules layout when installing with pnpm. The
# default pnpm layout (symlinks under .pnpm/<pkg>@<ver>/node_modules) breaks
# jest's `transformIgnorePatterns` regex because the resolved path contains
# `.pnpm/` and the patterns assume a flat `node_modules/<pkg>` shape (see
# jest.config.js). React Native + jest-expo specifically expect the flat
# layout — without this flag, every `expo`/`react-native` import in a test
# file throws "Cannot use import statement outside a module".
#
# `hoisted` makes pnpm behave like npm at install time while keeping its
# fast lockfile and disk-cache semantics. The only cost is duplicated
# transitive deps when versions conflict, which is acceptable here.
node-linker=hoisted
