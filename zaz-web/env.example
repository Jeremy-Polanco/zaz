# ── Web (Vite) ────────────────────────────────────────────────────
# Only VITE_* vars are exposed to the browser bundle.

# Base URL of the Bodeguita API (required — no default in production)
VITE_API_URL=https://api.bodeguita.com/api

# Stripe publishable key (required for credit self-payment)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Sentry DSN for error monitoring (optional — omit to disable Sentry entirely)
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Copy to `.env` for standalone runs. In docker compose this is injected
# from the root .env via compose interpolation (see docker-compose.yml).
