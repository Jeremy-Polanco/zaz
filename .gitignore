# ── Secrets ────────────────────────────────────────────────────────────────
# Never commit env files. The `*.example` templates are the source of truth
# for which vars exist; the real values live only on the deploy platforms.
.env
.env.*
!.env.example
!env.example
!*.env.example
!env.production.example

# ── Dependencies / builds (sub-projects also have their own .gitignore) ────
node_modules/
dist/
build/
coverage/
*.tsbuildinfo

# ── OS / editor cruft ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# ── Logs ───────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Provider local cache ──────────────────────────────────────────────────
.vercel/
.do/cache/

# ── Claude Code / agent workspace state ────────────────────────────────────
# Local-only LLM tooling state (huge, transient). The committable part of
# .claude/ — like CLAUDE.md — is whitelisted below.
.claude/projects/
.claude/settings.local.json
# .claude/skills/ are symlinks pointing into .agents/ (which is gitignored),
# so they're broken everywhere except this laptop. Don't track them.
**/.claude/skills/
.agents/
.atl/

# ── Engram persistent memory (local DB) ───────────────────────────────────
memory/
