# ==============================================================================
# bodeguita-api — environment variables
# Copy this file to .env and fill in real values. Never commit .env.
# ==============================================================================

# Application
NODE_ENV=development               # development | production | test
API_PORT=3001
CORS_ORIGIN=http://localhost:5173  # Comma-separated list for multiple origins
PUBLIC_WEB_URL=http://localhost:5173

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=bodeguita
DB_PASSWORD=change-me-db-password
DB_NAME=bodeguita_db
# Set to 'true' only in development/test. NEVER 'true' in production.
DB_SYNCHRONIZE=false
# Max connections in pool (default: 20)
DB_POOL_MAX=20

# JWT
# Must be at least 32 characters. Use: openssl rand -base64 48
JWT_SECRET=change-me-min-32-chars-jwt-secret-here
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_change-me
STRIPE_WEBHOOK_SECRET=whsec_change-me

# Twilio (uses API Key auth, not account auth token directly)
TWILIO_ACCOUNT_SID=ACchange-me
TWILIO_API_KEY_SID=SKchange-me
TWILIO_API_KEY_SECRET=change-me
TWILIO_FROM_NUMBER=+1234567890

# Shipping (optional — defaults used if not set)
SHIPPING_BASE_CENTS=300
SHIPPING_PER_MILE_CENTS=50

# Order SMS notifications
# Comma-separated list of E.164 phone numbers to receive new-order SMS alerts.
# Empty (default) disables the feature — safe to leave empty in development.
# Each entry must match /^\+[1-9]\d{9,14}$/ — malformed entries cause boot failure.
# Note: SMS body uses the pre-shipping subtotal (totalAmount at PENDING_QUOTE status).
# Example: ORDER_SMS_NOTIFY_NUMBERS=+18091234567,+19172541473
ORDER_SMS_NOTIFY_NUMBERS=
