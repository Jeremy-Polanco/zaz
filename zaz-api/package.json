{
  "name": "zaz-api",
  "private": true,
  "version": "1.0.0",
  "description": "Zaz multi-tenant water delivery API",
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "seed": "ts-node -r tsconfig-paths/register src/database/seed.ts",
    "test": "jest --selectProjects unit",
    "test:unit": "jest --selectProjects unit",
    "test:watch": "jest --selectProjects unit --watch",
    "test:cov": "jest --selectProjects unit --coverage",
    "test:integration": "jest --selectProjects integration --runInBand",
    "test:integration:watch": "jest --selectProjects integration --runInBand --watch",
    "test:concurrency": "jest --selectProjects integration --runInBand --testNamePattern @concurrency",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/jest/bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/database/data-source.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/data-source.ts"
  },
  "engines": {
    "npm": ">=10.0.0",
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.17",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^11.1.11",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.2",
    "@sentry/node": "^8.50.0",
    "@types/compression": "^1.8.1",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.1",
    "helmet": "^8.1.0",
    "joi": "^18.1.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^22.0.2",
    "twilio": "^5.13.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.8",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "globals": "^15.14.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "projects": [
      {
        "displayName": "unit",
        "testEnvironment": "node",
        "rootDir": "src",
        "testRegex": "\\.spec\\.ts$",
        "moduleFileExtensions": ["js", "json", "ts"],
        "transform": {
          "^.+\\.(t|j)s$": "ts-jest"
        }
      },
      {
        "displayName": "integration",
        "testEnvironment": "node",
        "rootDir": ".",
        "testRegex": "test/integration/.*\\.integration-spec\\.ts$",
        "moduleFileExtensions": ["js", "json", "ts"],
        "transform": {
          "^.+\\.(t|j)s$": "ts-jest"
        },
        "globalSetup": "./test/setup-integration.ts",
        "globalTeardown": "./test/teardown-integration.ts"
      }
    ],
    "collectCoverageFrom": [
      "src/**/*.(t|j)s",
      "!src/**/*.spec.ts",
      "!src/**/*.e2e-spec.ts",
      "!src/**/*.integration-spec.ts",
      "!src/test-utils/**",
      "!src/main.ts"
    ],
    "coverageDirectory": "./coverage",
    "coverageThreshold": {
      "src/modules/credit/**/*.ts": {
        "lines": 80,
        "branches": 80,
        "functions": 80
      },
      "src/modules/subscription/**/*.ts": {
        "lines": 80,
        "branches": 80,
        "functions": 80
      },
      "src/modules/orders/**/*.ts": {
        "lines": 80,
        "branches": 80,
        "functions": 80
      },
      "src/modules/payments/**/*.ts": {
        "lines": 80,
        "branches": 80,
        "functions": 80
      }
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@swc/core",
      "bcrypt"
    ]
  }
}
