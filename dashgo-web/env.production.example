# ── dashgo-web · production env vars (Vercel) ─────────────────────────────────
# Set these in Vercel → Project Settings → Environment Variables.
# Vite only exposes vars prefixed with VITE_ to the client bundle.

# ── API URL ─────────────────────────────────────────────────────────────────
# The deployed DO App Platform URL + /api prefix. No trailing slash.
VITE_API_URL=https://your-api.ondigitalocean.app/api

# ── Sentry (optional, recommended) ─────────────────────────────────────────
# DSN from the Sentry "Web" project. Leave empty to disable.
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Stripe publishable key ─────────────────────────────────────────────────
# Required: src/lib/stripe.ts throws on startup if this is missing.
# Use a pk_live_ key in production, pk_test_ for staging.
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
