# docker-compose infrastructure config — copy to `.env` at repo root.
# Per-app env is under bodeguita-api/env.example, bodeguita-web/env.example, bodeguita/env.example.

# ── Postgres ──────────────────────────────────────────────────────
POSTGRES_USER=bodeguita
POSTGRES_PASSWORD=bodeguita_dev
POSTGRES_DB=bodeguita_db
POSTGRES_HOST_PORT=5433

# ── Host port mappings ────────────────────────────────────────────
# Nota: 3001 y 8080 suelen estar ocupados en esta máquina (Next dev, weaviate).
API_HOST_PORT=3002
WEB_HOST_PORT=5173
ADMINER_PORT=8082

# ── Shared with containers (injected via compose) ─────────────────
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=30d
CORS_ORIGIN=http://localhost:5173
VITE_API_URL=http://localhost:3002/api

# ── Stripe ────────────────────────────────────────────────────────
# Server-side secret key. NEVER commit real values.
STRIPE_SECRET_KEY=sk_test_replace_me
# Webhook signing secret from `stripe listen` (local) or dashboard (prod).
STRIPE_WEBHOOK_SECRET=whsec_replace_me
