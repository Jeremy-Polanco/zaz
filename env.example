# docker-compose infrastructure config — copy to `.env` at repo root.
# Consumed by docker-compose.yml to interpolate config for the postgres,
# adminer, api, and web services. Per-app env lives under
# dashgo-api/env.example, dashgo-web/env.example, dashgo/env.example.
# NEVER commit real secrets — the values below are safe placeholders.

# ── Postgres ──────────────────────────────────────────────────────
POSTGRES_USER=dashgo
POSTGRES_PASSWORD=dashgo_dev
POSTGRES_DB=dashgo_db
POSTGRES_HOST_PORT=5433

# ── Host port mappings ────────────────────────────────────────────
# Nota: 3001 y 8080 suelen estar ocupados en esta máquina (Next dev, Adminer).
API_HOST_PORT=3002
WEB_HOST_PORT=5173
ADMINER_PORT=8082

# ── Shared with containers (injected via compose) ─────────────────
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=365d
CORS_ORIGIN=http://localhost:5173
VITE_API_URL=http://localhost:3002/api

# ── Stripe ────────────────────────────────────────────────────────
# Server-side secret key. NEVER commit real values.
STRIPE_SECRET_KEY=sk_test_replace_me
# Webhook signing secret from `stripe listen` (local) or dashboard (prod).
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# ── Twilio (SMS / WhatsApp OTP + order alerts) ────────────────────
# All four are interpolated into the api container by docker-compose.yml.
TWILIO_ACCOUNT_SID=AC_replace_me
TWILIO_API_KEY_SID=SK_replace_me
TWILIO_API_KEY_SECRET=replace_me
TWILIO_FROM_NUMBER=+14155238886

# ── Sentry error tracking ─────────────────────────────────────────
# Valid var NAMES (no hyphens / commas) so docker compose can parse the file.
# NOTE: docker-compose.yml does NOT yet pass these into the containers. To
# activate Sentry in the dockerized stack, add under services.api.environment:
#     SENTRY_DSN: ${SENTRY_DSN:-}
# and under services.web.environment:
#     VITE_SENTRY_DSN: ${VITE_SENTRY_DSN:-}
# API (NestJS) Sentry DSN — read by dashgo-api as process.env.SENTRY_DSN.
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# Web (React/Vite) Sentry DSN — read by dashgo-web as import.meta.env.VITE_SENTRY_DSN.
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ── Business config ───────────────────────────────────────────────
# Per-mile shipping rate in cents (dashgo-api shipping.service default: 50).
# Not yet injected into the api container by docker-compose.yml; to wire:
#     SHIPPING_PER_MILE_CENTS: ${SHIPPING_PER_MILE_CENTS:-50}
SHIPPING_PER_MILE_CENTS=50
