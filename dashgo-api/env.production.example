# ── dashgo-api · production env vars ──────────────────────────────────────────
# Copy this list to your platform's secret manager. NEVER commit real values.
#
# Most fields are validated at boot via Joi (src/app.module.ts). The app will
# refuse to start if any required var is missing or malformed.

# ── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=3001

# ── Database ────────────────────────────────────────────────────────────────
# DO App Platform binds these from the managed-database resource via tokens
# like ${dashgo-db.HOSTNAME} — see .do/app.yaml. For other providers (Render,
# Neon, Supabase), paste the values from their dashboard.
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=
# 'true' for managed Postgres (DO/Render/Neon/Supabase). Use 'ca' + DB_SSL_CA
# (PEM) for stricter verification when the provider gives you a CA bundle.
DB_SSL=true
# DB_SSL_CA=<PEM bundle here>
DB_POOL_MAX=20
# IMPORTANT: leave 'false' in production. The boot config also forces this.
DB_SYNCHRONIZE=false

# ── Auth ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_RANDOM_STRING_MIN_32_CHARS
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=30d

# ── OTP delivery mode ──────────────────────────────────────────────────────
# Controls whether a verification code is sent + enforced at login.
#
#   disabled  — DEFAULT. Phone-only login: NO code is sent and login succeeds
#               on the phone number alone. This is the canonical product
#               behavior. SECURITY: anyone who knows a registered phone can
#               sign in as that user — there is no second factor.
#   whatsapp  — RE-ENABLE OTP: send via Twilio WhatsApp Business template.
#               Requires TWILIO_WHATSAPP_FROM + TWILIO_WHATSAPP_OTP_TEMPLATE_SID.
#   sandbox   — RE-ENABLE OTP via Twilio WhatsApp Sandbox (free-form text).
#               Each tester opts in by texting `join <code>` to the sandbox.
#
# Leave unset (or `disabled`) for phone-only login. Set to whatsapp|sandbox to
# turn verified login back on — the OTP code path is dormant, not deleted.
AUTH_OTP_MODE=disabled

# ── CORS / public URL ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash).
CORS_ORIGIN=https://your-app.vercel.app
PUBLIC_WEB_URL=https://your-app.vercel.app

# ── Stripe (TEST mode for now) ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Required in production by Joi schema. Create a Price in Stripe for the
# subscription product, copy its price_... id here.
STRIPE_SUBSCRIPTION_PRICE_ID=price_...

# ── Twilio (PROD credentials) ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_API_KEY_SID=SK...
TWILIO_API_KEY_SECRET=
# SMS sender — used for admin order notifications. Buy a US local number
# in the Twilio Console (~$1.15/mo). Not used for OTP (that goes via
# WhatsApp below).
TWILIO_FROM_NUMBER=+1...

# ── WhatsApp Business via Twilio (OTP path) ────────────────────────────────
# OTPs are sent through WhatsApp because A2P 10DLC SMS registration is heavy
# and DashGo's audience uses WhatsApp by default.
#
# `whatsapp:+1<your-WA-number>` for production (your verified WhatsApp
# sender), or `whatsapp:+14155238886` for the Twilio sandbox.
TWILIO_WHATSAPP_FROM=whatsapp:+1...
#
# Content Template SID (HX…) of the approved Spanish OTP template. Required
# outside the sandbox — Meta enforces template usage for business-initiated
# WhatsApp messages. Submit the template in Twilio Console → Content Template
# Builder → New WhatsApp authentication template.
TWILIO_WHATSAPP_OTP_TEMPLATE_SID=HX...

# ── Sentry (REQUIRED in production) ───────────────────────────────────────
# REQUIRED when NODE_ENV=production. Paste DSN from the Sentry "API" project
# (Settings → Projects → dashgo-api → Client Keys (DSN)). MUST start with
# `https://` — the schema rejects `http://` because Sentry's ingest endpoints
# are HTTPS-only and a typo would silently drop every event.
#
# Privacy note: we intentionally do NOT call Sentry.setUser(). Events ship
# without phone/email/user-id so the mobile app's "Not Linked" privacy
# declaration (assets/PrivacyInfo.xcprivacy) stays accurate.
SENTRY_DSN=https://<public-key>@<org>.ingest.sentry.io/<project-id>
# Fraction of requests with full trace data. 0.1 = 10%. Keep low in prod to
# stay under the Sentry quota; bump for short-lived debug windows.
SENTRY_TRACES_SAMPLE_RATE=0.1
# Fraction of TRACED requests that also get CPU profiles. Cheap because it's
# a subset of the traces above. 0.1 means 1% of all requests get profiled.
SENTRY_PROFILES_SAMPLE_RATE=0.1
# Release tag — OPTIONAL but STRONGLY RECOMMENDED at deploy time.
# Must match the `--release` value passed to `sentry-cli sourcemaps upload`
# so uploaded maps can be matched to runtime events. Typical formats:
#   - git short SHA:        a3f9b21
#   - semver tag:           1.2.3
#   - name@semver+sha:      dashgo-api@1.2.3+a3f9b21
# When unset, falls back to npm_package_version from package.json (still
# works locally, but breaks source-map matching across deploys of the same
# version). Set this in your CI/CD pipeline (DO App Platform, GitHub
# Actions, etc.) and use the SAME value for the source-map upload step.
# SENTRY_RELEASE=
